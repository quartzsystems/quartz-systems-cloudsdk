# NOTE: cargo/rustc are intentionally NOT build-deps. Debian bookworm ships
# Rust 1.63, too old for this backend (axum 0.7 needs ~1.75). A current
# toolchain is provided via rustup at build time — see ../build-deb.sh.
Source: quartz-cloudsdk-webui
Section: net
Priority: optional
Maintainer: Quartz Systems <cwellman@quartz.systems>
Build-Depends:
 debhelper-compat (= 13),
 build-essential,
Standards-Version: 4.6.2
Rules-Requires-Root: no

Package: quartz-cloudsdk-webui
Architecture: any
Depends:
 ${shlibs:Depends},
 ${misc:Depends},
 openssl,
Description: Quartz CloudSDK web management interface
 Rust backend that serves the exported Next.js frontend over TLS on :4443 and
 reverse-proxies requests to a Telecom Infra Project CloudSDK deployment,
 authenticating operators against the CloudSDK security service (owsec) and
 injecting the bearer token server-side. Ships a systemd unit enabled on
 installation.
